# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=SwissUnihockey API
VERSION=1.0.0
DEBUG=true

# CORS - Allow frontend origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]

# SwissUnihockey API Integration
SWISSUNIHOCKEY_API_URL=https://api-v2.swissunihockey.ch
SWISSUNIHOCKEY_LOCALE=de-CH
SWISSUNIHOCKEY_CACHE_ENABLED=true
SWISSUNIHOCKEY_CACHE_DIR=../data/cache

# Redis (Optional - comment out if not using)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Database (Optional - PostgreSQL for persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/swissunihockey

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Admin dashboard protection
ADMIN_PIN=change-me
SESSION_SECRET=change-me-to-a-long-random-string
